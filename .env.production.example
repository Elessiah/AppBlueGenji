# ------------------------------------------------------------------
# BlueGenji Arena — .env de PRODUCTION (modèle)
# ------------------------------------------------------------------
# Copier vers .env.production (ou .env sur l'hôte) puis remplir.
# Ne JAMAIS committer le vrai fichier avec des secrets.
# ------------------------------------------------------------------

# Mode Next.js — DOIT être "production" (désactive le bypass DEV_AUTH_USER_ID
# et active le flag `secure` sur les cookies de session/OAuth).
NODE_ENV=production

# ------------------------------------------------------------------
# URL publique de l'application
# ------------------------------------------------------------------
# OBLIGATOIRE en prod. Sert de base à toutes les redirections OAuth
# (start + callback). Sans cette variable, Next.js retombe sur l'hôte
# interne vu par le serveur (ex: http://localhost:3000) et redirige
# le navigateur vers localhost après la callback Google.
#
# Doit correspondre EXACTEMENT au domaine public servi par le reverse-proxy,
# sans slash final.
APP_URL=https://arena.bluegenji.fr

# ------------------------------------------------------------------
# Base de données MySQL
# ------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_USER=bluegenji
DB_PASSWORD=__REMPLACER__
DB_DATABASE=bluegenji_arena

# ------------------------------------------------------------------
# Google OAuth 2.0
# ------------------------------------------------------------------
# Récupérés dans Google Cloud Console > APIs & Services > Credentials.
# Le client OAuth (type "Web application") doit lister EXACTEMENT
# GOOGLE_REDIRECT_URI dans "Authorized redirect URIs".
GOOGLE_CLIENT_ID=__REMPLACER__.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=__REMPLACER__

# URI de callback OAuth. Doit pointer vers le domaine public (APP_URL)
# et être déclarée à l'identique côté Google Cloud Console.
GOOGLE_REDIRECT_URI=https://arena.bluegenji.fr/api/auth/google/callback

# ------------------------------------------------------------------
# Intégration bot Discord (optionnel)
# ------------------------------------------------------------------
# URL interne du bot (localhost si même hôte, IP/DNS privé sinon).
BOT_INTERNAL_URL=http://127.0.0.1:4400
# Doit correspondre à INTERNAL_API_TOKEN du bot.
BOT_INTERNAL_TOKEN=__REMPLACER__

# ------------------------------------------------------------------
# Contact RGPD (optionnel)
# ------------------------------------------------------------------
# Adresse affichée sur la page /rgpd. Si absente, utilise le fallback
# défini dans lib/shared/rgpd-policy.ts. Préférer une adresse dédiée
# (ex: rgpd@bluegenji.fr) pour éviter l'exposition d'une adresse personnelle.
# RGPD_CONTACT_EMAIL=rgpd@bluegenji.fr

# Identifiant de l'application Discord, utilisé pour générer le lien
# d'invitation OAuth2 du bot (pages /bot — BotHero, BotInviteCard).
# Sans cette variable, le bouton « Inviter le bot » reste inerte (href="#").
DISCORD_BOT_CLIENT_ID=__REMPLACER__
# Bitfield de permissions demandé à l'invitation (optionnel).
# Défaut : 1099511627776 (bot + applications.commands).
DISCORD_BOT_PERMISSIONS=1099511627776

# ------------------------------------------------------------------
# Bypass d'authentification dev — NE JAMAIS DÉFINIR EN PRODUCTION
# ------------------------------------------------------------------
# La fonction getCurrentUser() ignore cette variable quand NODE_ENV=production,
# mais on la laisse explicitement vide pour éviter toute confusion.
# DEV_AUTH_USER_ID=
